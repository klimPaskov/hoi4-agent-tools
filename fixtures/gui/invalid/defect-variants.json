{
  "schemaVersion": 1,
  "variants": [
    {
      "id": "conflicting-tabs",
      "scenario": {
        "elementStates": {
          "tab_logistics": "selected"
        }
      },
      "expectedDiagnosticCodes": ["GUI_TAB_STATE_CONFLICT"]
    },
    {
      "id": "visible-element-overlap",
      "sourceReplacements": [
        {
          "relativePath": "interface/synthetic_acceptance.gui",
          "search": "name = \"tab_operations\"\n\t\t\tposition = { x = 220 y = 145 }",
          "replacement": "name = \"tab_operations\"\n\t\t\tposition = { x = 40 y = 145 }"
        }
      ],
      "expectedDiagnosticCodes": ["GUI_VISIBLE_OVERLAP", "GUI_CONFLICTING_CLICK_REGIONS"]
    },
    {
      "id": "cost-mismatch",
      "sourceReplacements": [
        {
