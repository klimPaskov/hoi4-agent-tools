# Read-only local stdio needs only a configuration path.
HOI4_AGENT_CONFIG=/absolute/path/to/config.json

# Optional setup discovery inputs. They report candidates only; they do not grant access or
# register workspaces. Separate multiple mod roots with the OS path delimiter (`:` on POSIX,
# `;` on Windows).
HOI4_GAME_ROOT=/absolute/path/to/game
HOI4_MOD_ROOTS=/absolute/path/to/mod-a:/absolute/path/to/mod-b

# Loopback HTTP reads the token from the environment name referenced by server configuration.
# Use a random value of at least 32 characters. Static tokens are not accepted on public binds.
HOI4_AGENT_HTTP_TOKEN=replace-with-a-long-random-secret

# Public allowed origins and OAuth endpoints belong in the reviewed JSON configuration.
