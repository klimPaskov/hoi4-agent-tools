# Optional overrides used by setup discovery.
HOI4_GAME_ROOT=/absolute/path/to/Hearts of Iron IV
HOI4_MOD_ROOTS=/absolute/path/to/folder-containing-mods

# Optional custom server configuration. The default per-user config needs no environment variable.
HOI4_AGENT_CONFIG=/absolute/path/to/config.json

# Example bearer secret for loopback Streamable HTTP. The JSON config refers to this variable name.
HOI4_AGENT_HTTP_TOKEN=replace-with-a-long-random-secret
