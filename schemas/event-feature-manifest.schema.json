{
  "$id": "https://github.com/klimPaskov/hoi4-agent-tools/blob/v1.2.0/schemas/event-feature-manifest.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "eventIds": {
      "maxItems": 2000,
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema0"
      }
    },
    "namespaces": {
      "maxItems": 500,
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema1"
      }
    },
    "sourcePaths": {
      "maxItems": 2000,
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema2"
      }
    },
    "nodeIds": {
      "maxItems": 5000,
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema3"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "__schema0": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "__schema1": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "__schema2": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "__schema3": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    }
  }
}
