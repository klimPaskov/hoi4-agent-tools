{
  "$id": "https://github.com/klimPaskov/hoi4-agent-tools/blob/v0.1.1/schemas/transaction-manifest.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "version": {
      "type": "number",
      "const": 1
    },
    "revision": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "transactionId": {
      "type": "string",
      "pattern": "^txn_[0-9a-f-]{36}$"
    },
    "workspaceId": {
      "$ref": "#/$defs/__schema0"
    },
    "principal": {
      "type": "string",
      "maxLength": 1024
    },
    "rootFingerprint": {
      "$ref": "#/$defs/__schema1"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "state": {
      "type": "string",
      "enum": [
        "planned",
        "applying",
        "applied",
        "rolling_back",
        "rolled_back",
        "failed"
      ]
    },
    "planPayload": {
      "type": "object",
      "properties": {
        "version": {
          "type": "number",
          "const": 1
        },
        "workspaceId": {
          "$ref": "#/$defs/__schema0"
        },
        "principal": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 1024
            },
            {
              "type": "null"
            }
          ]
        },
        "rootFingerprint": {
          "$ref": "#/$defs/__schema1"
        },
        "operationKind": {
          "$ref": "#/$defs/__schema2"
        },
        "operations": {
          "maxItems": 1000,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema3"
          }
        },
        "readDependencies": {
          "maxItems": 10000,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema5"
          }
        },
        "files": {
          "maxItems": 1000,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema7"
          }
        },
        "diagnostics": {
          "maxItems": 100,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema16"
          }
        },
        "validation": {
          "$ref": "#/$defs/__schema19"
        },
        "artifacts": {
          "maxItems": 512,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema21"
          }
        }
      },
      "required": [
        "version",
        "workspaceId",
        "principal",
        "rootFingerprint",
        "operationKind",
        "operations",
        "readDependencies",
        "files",
        "diagnostics",
        "validation",
        "artifacts"
      ],
      "additionalProperties": false
    },
    "planHash": {
      "$ref": "#/$defs/__schema1"
    },
    "integrityHash": {
      "$ref": "#/$defs/__schema1"
    },
    "authenticationTag": {
      "$ref": "#/$defs/__schema1"
    },
    "operationKind": {
      "$ref": "#/$defs/__schema2"
    },
    "operations": {
      "maxItems": 1000,
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema3"
      }
    },
    "readDependencies": {
      "maxItems": 10000,
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema5"
      }
    },
    "files": {
      "maxItems": 1000,
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema22"
      }
    },
    "diagnostics": {
      "maxItems": 100,
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema16"
      }
    },
    "validation": {
      "$ref": "#/$defs/__schema19"
    },
    "artifacts": {
      "maxItems": 512,
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema21"
      }
    },
    "appliedFiles": {
      "maxItems": 1000,
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema6"
      }
    },
    "rollbackStatus": {
      "type": "string",
      "enum": [
        "available",
        "applied",
        "failed"
      ]
    },
    "failure": {
      "type": "object",
      "properties": {
        "code": {
          "$ref": "#/$defs/__schema2"
        },
        "message": {
          "$ref": "#/$defs/__schema4"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "version",
    "revision",
    "transactionId",
    "workspaceId",
    "rootFingerprint",
    "createdAt",
    "expiresAt",
    "state",
    "planPayload",
    "planHash",
    "integrityHash",
    "authenticationTag",
    "operationKind",
    "operations",
    "readDependencies",
    "files",
    "diagnostics",
    "validation",
    "artifacts",
    "appliedFiles",
    "rollbackStatus"
  ],
  "additionalProperties": false,
  "$defs": {
    "__schema0": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{0,63}$"
    },
    "__schema1": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "__schema2": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "__schema3": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/__schema2"
        },
        "kind": {
          "$ref": "#/$defs/__schema2"
        },
        "summary": {
          "$ref": "#/$defs/__schema4"
        },
        "data": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "maxLength": 256
          },
          "additionalProperties": {}
        }
      },
      "required": [
        "id",
        "kind",
        "summary",
        "data"
      ],
      "additionalProperties": false
    },
    "__schema4": {
      "type": "string",
      "maxLength": 4096
    },
    "__schema5": {
      "type": "object",
      "properties": {
        "rootKind": {
          "type": "string",
          "enum": [
            "mod",
            "game",
            "dependency",
            "artifact",
            "cache",
            "fixture"
          ]
        },
        "loadOrder": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "relativePath": {
          "$ref": "#/$defs/__schema6"
        },
        "sha256": {
          "$ref": "#/$defs/__schema1"
        }
      },
      "required": [
        "rootKind",
        "loadOrder",
        "relativePath",
        "sha256"
      ],
      "additionalProperties": false
    },
    "__schema6": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "__schema7": {
      "type": "object",
      "properties": {
        "relativePath": {
          "$ref": "#/$defs/__schema6"
        },
        "operationIds": {
          "$ref": "#/$defs/__schema8"
        },
        "beforeSha256": {
          "$ref": "#/$defs/__schema9"
        },
        "afterSha256": {
          "$ref": "#/$defs/__schema10"
        },
        "beforeSize": {
          "$ref": "#/$defs/__schema11"
        },
        "afterSize": {
          "$ref": "#/$defs/__schema12"
        },
        "beforeBlob": {
          "$ref": "#/$defs/__schema13"
        },
        "afterBlob": {
          "$ref": "#/$defs/__schema14"
        },
        "mediaType": {
          "$ref": "#/$defs/__schema15"
        }
      },
      "required": [
        "relativePath",
        "operationIds",
        "beforeSha256",
        "afterSha256",
        "beforeSize",
        "afterSize",
        "beforeBlob",
        "afterBlob",
        "mediaType"
      ],
      "additionalProperties": false
    },
    "__schema8": {
      "maxItems": 1000,
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema2"
      }
    },
    "__schema9": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema1"
        },
        {
          "type": "null"
        }
      ]
    },
    "__schema10": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema1"
        },
        {
          "type": "null"
        }
      ]
    },
    "__schema11": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ]
    },
    "__schema12": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        {
          "type": "null"
        }
      ]
    },
    "__schema13": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema6"
        },
        {
          "type": "null"
        }
      ]
    },
    "__schema14": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema6"
        },
        {
          "type": "null"
        }
      ]
    },
    "__schema15": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "__schema16": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "error",
            "blocker"
          ]
        },
        "category": {
          "type": "string",
          "enum": [
            "syntax",
            "reference",
            "layout",
            "design",
            "rendering",
            "security",
            "transaction",
            "map",
            "configuration"
          ]
        },
        "message": {
          "type": "string",
          "maxLength": 4096
        },
        "location": {
          "$ref": "#/$defs/__schema17"
        },
        "related": {
          "maxItems": 100,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema17"
          }
        },
        "operationId": {
          "type": "string",
          "maxLength": 256
        },
        "details": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "maxLength": 256
          },
          "additionalProperties": {}
        }
      },
      "required": [
        "code",
        "severity",
        "category",
        "message"
      ],
      "additionalProperties": false
    },
    "__schema17": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "start": {
          "$ref": "#/$defs/__schema18"
        },
        "end": {
          "$ref": "#/$defs/__schema18"
        },
        "symbol": {
          "type": "string",
          "maxLength": 1024
        }
      },
      "required": [
        "path",
        "start",
        "end"
      ],
      "additionalProperties": false
    },
    "__schema18": {
      "type": "object",
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "column": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "offset": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "line",
        "column",
        "offset"
      ],
      "additionalProperties": false
    },
    "__schema19": {
      "type": "object",
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "checks": {
          "maxItems": 100,
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema20"
          }
        }
      },
      "required": [
        "passed",
        "checks"
      ],
      "additionalProperties": false
    },
    "__schema20": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/__schema2"
        },
        "passed": {
          "type": "boolean"
        },
        "message": {
          "$ref": "#/$defs/__schema4"
        }
      },
      "required": [
        "id",
        "passed",
        "message"
      ],
      "additionalProperties": false
    },
    "__schema21": {
      "type": "object",
      "properties": {
        "uri": {
          "type": "string",
          "maxLength": 4096,
          "format": "uri"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "mimeType": {
          "$ref": "#/$defs/__schema15"
        },
        "size": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "sha256": {
          "$ref": "#/$defs/__schema1"
        },
        "description": {
          "type": "string",
          "maxLength": 4096
        }
      },
      "required": [
        "uri",
        "name",
        "mimeType"
      ],
      "additionalProperties": false
    },
    "__schema22": {
      "type": "object",
      "properties": {
        "relativePath": {
          "$ref": "#/$defs/__schema6"
        },
        "operationIds": {
          "$ref": "#/$defs/__schema8"
        },
        "beforeSha256": {
          "$ref": "#/$defs/__schema9"
        },
        "afterSha256": {
          "$ref": "#/$defs/__schema10"
        },
        "beforeSize": {
          "$ref": "#/$defs/__schema11"
        },
        "afterSize": {
          "$ref": "#/$defs/__schema12"
        },
        "beforeBlob": {
          "$ref": "#/$defs/__schema13"
        },
        "afterBlob": {
          "$ref": "#/$defs/__schema14"
        },
        "mediaType": {
          "$ref": "#/$defs/__schema15"
        },
        "diffArtifact": {
          "$ref": "#/$defs/__schema21"
        }
      },
      "required": [
        "relativePath",
        "operationIds",
        "beforeSha256",
        "afterSha256",
        "beforeSize",
        "afterSize",
        "beforeBlob",
        "afterBlob",
        "mediaType"
      ],
      "additionalProperties": false
    }
  }
}
