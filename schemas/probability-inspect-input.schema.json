{
  "$id": "https://github.com/klimPaskov/hoi4-agent-tools/blob/v2.3.0/schemas/probability-inspect-input.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "workspaceId": {
      "default": "current",
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{0,63}$"
    },
    "adapter": {
      "type": "string",
      "enum": [
        "event_mean_time_to_happen",
        "event_option_ai_chance",
        "decision_ai_will_do",
        "mission_ai_will_do",
        "national_focus_ai_will_do",
        "technology_ai_will_do",
        "doctrine_ai_will_do",
        "direct_random",
        "random_list",
        "ai_strategy_factor",
        "custom_weighted_pool"
      ]
    },
    "source": {
      "type": "object",
      "properties": {
        "identifier": {
          "$ref": "#/$defs/__schema0"
        },
        "path": {
          "$ref": "#/$defs/__schema1"
        },
        "line": {
          "$ref": "#/$defs/__schema2"
        },
        "inlineClausewitz": {
          "$ref": "#/$defs/__schema3"
        },
        "virtualPatch": {
          "$ref": "#/$defs/__schema4"
        },
        "expectedSourceHash": {
          "$ref": "#/$defs/__schema5"
        }
      },
      "additionalProperties": false
    },
    "candidatePool": {
      "maxItems": 100000,
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema6"
      }
    },
    "refresh": {
      "type": "boolean"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "__schema0": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "__schema1": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "__schema2": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "__schema3": {
      "type": "string",
      "maxLength": 16777216
    },
    "__schema4": {
      "type": "string",
      "maxLength": 16777216
    },
    "__schema5": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "__schema6": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    }
  }
}
