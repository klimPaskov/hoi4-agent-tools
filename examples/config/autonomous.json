{
  "version": 1,
  "writePolicy": "autonomous",
  "serverStateRoot": "/var/lib/hoi4-agent-tools-state",
  "registrationRoots": ["/projects/hoi4-mods", "/games/Hearts of Iron IV"],
  "writableRegistrationRoots": ["/projects/hoi4-mods"],
  "storageRoots": ["/var/lib/hoi4-agent-tools"],
  "workspaces": [
    {
      "id": "my_mod",
      "name": "My Mod",
      "root": "/projects/hoi4-mods/my-mod",
      "gameRoot": "/games/Hearts of Iron IV",
      "dependencyRoots": [],
      "replacePaths": [],
      "artifactRoot": "/var/lib/hoi4-agent-tools/my-mod/artifacts",
      "cacheRoot": "/var/lib/hoi4-agent-tools/my-mod/cache",
      "writeEnabled": true
    }
  ]
}
